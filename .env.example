# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# OpenRouter — powers the AI Project Brief Generator.
# Get a key at https://openrouter.ai/keys — free credits to start.
NUXT_OPENROUTER_API_KEY=

# Optional: override the model used for the brief generator.
# Defaults to anthropic/claude-sonnet-4.5 if unset.
NUXT_OPENROUTER_MODEL=

# Web3Forms — receives lead emails from the brief generator.
# Go to https://web3forms.com and enter the email you want leads delivered to.
# For Ailen: use ailengonzalez21.ag@gmail.com. Web3Forms emails you an access key
# bound to that address — paste it here. The lead email destination is locked
# to whichever email you used to generate the key.
NUXT_PUBLIC_WEB3FORMS_KEY=
